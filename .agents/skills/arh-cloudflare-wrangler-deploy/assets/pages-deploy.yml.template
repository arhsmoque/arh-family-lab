name: Deploy <UNIT_NAME> to Cloudflare Pages

# Independent deploy unit. Triggers only on changes under <UNIT_PATH>/**, never blocked by or
# blocking any other unit's deploy. Dormant (fails fast, clearly) until CLOUDFLARE_API_TOKEN and
# CLOUDFLARE_ACCOUNT_ID exist as repository (or environment) secrets.

on:
  push:
    branches: [main]
    paths:
      - "<UNIT_PATH>/**"
  workflow_dispatch:

concurrency:
  group: deploy-<UNIT_NAME>
  cancel-in-progress: false

jobs:
  deploy:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      deployments: write

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "22"
          cache: "npm"

      - name: Install dependencies
        run: npm ci

      - name: Build
        run: npm run build --workspace=<UNIT_NAME> # or your unit's actual build command
        env:
          # Add unit-specific build-time secrets here, sourced from GitHub Actions secrets only.
          # VITE_EXAMPLE_URL: ${{ secrets.VITE_EXAMPLE_URL }}
          NODE_ENV: production

      - name: Check Cloudflare credentials are configured
        run: |
          if [ -z "${{ secrets.CLOUDFLARE_API_TOKEN }}" ] || [ -z "${{ secrets.CLOUDFLARE_ACCOUNT_ID }}" ]; then
            echo "::error::CLOUDFLARE_API_TOKEN and/or CLOUDFLARE_ACCOUNT_ID repository secrets are not set. Add them (Settings > Secrets and variables > Actions) to enable deployment."
            exit 1
          fi

      - name: Deploy to Cloudflare Pages
        run: npx wrangler pages deploy <BUILD_OUTPUT_DIR> --project-name=<CLOUDFLARE_PROJECT_NAME> --branch=main
        env:
          CLOUDFLARE_API_TOKEN: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          CLOUDFLARE_ACCOUNT_ID: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
